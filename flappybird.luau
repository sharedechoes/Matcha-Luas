local function base64decode(data)
    if not data or type(data) ~= "string" then return "" end
    local chars = {}
    for x in string.gmatch(string.gsub(data, '[^ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=]', ''):gsub('.', function(x)
        if (x == '=') then return '' end
        local r,f='',string.find('ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/',x)-1
        for i=6,1,-1 do r=r..(f%2^i-f%2^(i-1)>0 and '1' or '0') end
        return r
    end), '%d%d%d%d%d%d%d%d') do
        local c=0
        for i=1,8 do c=c+(x:sub(i,i)=='1' and 2^(8-i) or 0) end
        table.insert(chars, string.char(c))
    end
    return table.concat(chars)
end

local assets_cache = {}
local function get_asset(name)
    if assets_cache[name] then
        return assets_cache[name]
    end
    if spr[name] then
        local decoded = base64decode(spr[name])
        assets_cache[name] = decoded
        return decoded
    end
    return ""
end

local current_assets = {}
local function set_asset(draw_obj, asset_name)
    if current_assets[draw_obj] ~= asset_name then
        draw_obj.Data = get_asset(asset_name)
        current_assets[draw_obj] = asset_name
    end
end

local function getKeyValue(key)
    if not key then return nil end
    if type(key) == "number" then return key end
    local success, val = pcall(function() return key.Value end)
    if success and val then return val end
    local successName, name = pcall(function() return key.Name end)
    if successName and name then return name end
    return tostring(key)
end

local function intersects(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2)
    return ax1 < bx2 and ax2 > bx1 and ay1 < by2 and ay2 > by1
end

local state = "menu"
local birdX = 60
local birdY = 150
local vy = 0
local bobTimer = 0
local flapTimer = 0
local flapFrame = 1

local groundOffsetX = 0
local pipes = {}
local score = 0
local spaceWasDown = false
local lmbWasDown = false

local scale = 1.5
local w = 288 * scale
local h = 512 * scale
local gameX = 0
local gameY = 0

local connections = {}
local function trackConnection(conn)
    table.insert(connections, conn)
end

local draw_border = Drawing.new("Square")
local draw_bg = Drawing.new("Image")
local draw_base = Drawing.new("Image")
local draw_bird = Drawing.new("Image")
local draw_pipes = {}
for i = 1, 6 do
    draw_pipes[i] = Drawing.new("Image")
end
local draw_digits = {}
for i = 1, 4 do
    draw_digits[i] = Drawing.new("Image")
end
local draw_high_digits = {}
for i = 1, 4 do
    draw_high_digits[i] = Drawing.new("Image")
end
local draw_message = Drawing.new("Image")
local draw_gameover = Drawing.new("Image")
local draw_left_cover = Drawing.new("Square")
local draw_right_cover = Drawing.new("Square")

local particles = {}
local function spawn_particle(x, y, vx, vy, color, size, decay)
    local draw = Drawing.new("Circle")
    draw.Filled = true
    draw.Color = color
    draw.Visible = false
    draw.ZIndex = 4
    table.insert(particles, {
        draw = draw,
        x = x,
        y = y,
        vx = vx,
        vy = vy,
        life = 1.0,
        decay = decay or 1.0,
        size = size or 2
    })
end

local function cleanup()
    for _, conn in ipairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    connections = {}
    
    pcall(function()
        draw_border:Remove()
        draw_bg:Remove()
        draw_base:Remove()
        draw_bird:Remove()
        draw_message:Remove()
        draw_gameover:Remove()
        draw_left_cover:Remove()
        draw_right_cover:Remove()
        for i = 1, 6 do draw_pipes[i]:Remove() end
        for i = 1, 4 do draw_digits[i]:Remove() end
        for i = 1, 4 do draw_high_digits[i]:Remove() end
        for _, p in ipairs(particles) do p.draw:Remove() end
    end)
    particles = {}
    print("connections and drawings cleaned up")
end
local draw_highscore = Drawing.new("Text")

draw_highscore.Size = 14
draw_highscore.Font = Drawing.Fonts.UI
draw_highscore.Color = Color3.fromRGB(240, 140, 40)
draw_highscore.Outline = true
draw_highscore.Center = true

local function jump()
    if state == "menu" then
        state = "playing"
        vy = -cfg.jump
        score = 0
        pipes = {}
        print("game started")
        for _ = 1, 3 do
            spawn_particle(
                birdX,
                birdY + 12,
                math.random(-60, -20),
                math.random(-30, 30),
                Color3.fromRGB(240, 240, 255),
                1.5 + math.random() * 1.5,
                1.2 + math.random() * 0.8
            )
        end
    elseif state == "playing" then
        vy = -cfg.jump
        for _ = 1, 3 do
            spawn_particle(
                birdX,
                birdY + 12,
                math.random(-60, -20),
                math.random(-30, 30),
                Color3.fromRGB(240, 240, 255),
                1.5 + math.random() * 1.5,
                1.2 + math.random() * 0.8
            )
        end
    elseif state == "gameover" then
        state = "menu"
        birdY = 150
        vy = 0
        pipes = {}
        print("game reset")
    end
end

trackConnection(game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
    local key = getKeyValue(input.KeyCode)
    if key == "Space" then
        if processed then return end
        if cfg.active then
            jump()
        end
    end
end))

local lastTick = os.clock()

trackConnection(game:GetService("RunService").RenderStepped:Connect(function()
    local screen = select(2, pcall(function() return workspace.CurrentCamera.ViewportSize end)) or Vector2.new(800, 600)
    scale = math.min(cfg.scale, screen.Y / 512)
    w = 288 * scale
    h = 512 * scale
    gameX = (screen.X - w) / 2
    gameY = (screen.Y - h) / 2
    
    if not cfg.active then
        draw_border.Visible = false
        draw_bg.Visible = false
        draw_base.Visible = false
        draw_bird.Visible = false
        draw_message.Visible = false
        draw_gameover.Visible = false
        draw_highscore.Visible = false
        draw_left_cover.Visible = false
        draw_right_cover.Visible = false
        draw_coin_icon.Visible = false
        for i = 1, 6 do draw_pipes[i].Visible = false end
        for i = 1, 4 do draw_digits[i].Visible = false end
        for i = 1, 4 do draw_high_digits[i].Visible = false end
        return
    end
    
    local spacePressed = iskeypressed(0x20)
    if spacePressed and not spaceWasDown then
        jump()
    end
    spaceWasDown = spacePressed

    local lmbPressed = ismouse1pressed()
    if lmbPressed and not lmbWasDown then
        local mouse = game:GetService("Players").LocalPlayer:GetMouse()
        local mx, my = mouse.X, mouse.Y
        local inBoard = (mx >= gameX and mx <= gameX + w and my >= gameY and my <= gameY + h)
        if inBoard then
            jump()
        end
    end
    lmbWasDown = lmbPressed

    local now = os.clock()
    local dt = now - lastTick
    lastTick = now
    if dt > 0.1 then dt = 0.1 end
    
    if state == "menu" then
        bobTimer = bobTimer + dt * 4
        birdY = 150 + math.sin(bobTimer) * 8
        groundOffsetX = (groundOffsetX + cfg.speed * dt) % 24
        flapTimer = flapTimer + dt
        if flapTimer > 0.15 then
            flapTimer = 0
            flapFrame = (flapFrame % 3) + 1
        end
    elseif state == "playing" then
        if cfg.bot then
            local nextPipe = nil
            for i = 1, #pipes do
                local p = pipes[i]
                if p.x + 52 > birdX then
                    nextPipe = p
                    break
                end
            end
            if nextPipe then
                local predictedY = birdY + vy * 0.15 + 0.5 * cfg.gravity * 0.0225
                if predictedY > nextPipe.gapY + 10 then
                    jump()
                end
            else
                if birdY > 200 then
                    jump()
                end
            end
        end
        
        vy = vy + cfg.gravity * dt
        birdY = birdY + vy * dt
        if birdY < 0 then
            birdY = 0
            vy = 0
        end
        
        groundOffsetX = (groundOffsetX + cfg.speed * dt) % 24
        
        flapTimer = flapTimer + dt
        if flapTimer > 0.15 then
            flapTimer = 0
            flapFrame = (flapFrame % 3) + 1
        end
        
        for i = #pipes, 1, -1 do
            local p = pipes[i]
            p.x = p.x - cfg.speed * dt
            if p.x < -52 then
                table.remove(pipes, i)
            end
        end
        
        if #pipes == 0 or (288 - pipes[#pipes].x) >= 150 then
            local gapY = math.random(120, 280)
            table.insert(pipes, {
                x = 288,
                gapY = gapY,
                passed = false
            })
        end
        
        if birdY + 24 >= 400 then
            state = "gameover"
            vy = 0
            if score > cfg.highscore then
                cfg.highscore = score
                pcall(function() writefile("flappy_highscore.txt", tostring(score)) end)
                print("new highscore " .. tostring(score))
            end
            print("ground hit")
            for _ = 1, 12 do
                spawn_particle(
                    birdX + 17,
                    birdY + 12,
                    math.random(-120, 120),
                    math.random(-150, 50),
                    Color3.fromRGB(255, math.random(80, 200), 20),
                    2.0 + math.random() * 2.0,
                    2.0 + math.random() * 1.5
                )
            end
        end
        
        for i = 1, #pipes do
            local p = pipes[i]
            if intersects(birdX, birdY, birdX + 34, birdY + 24, p.x, 0, p.x + 52, p.gapY - 50) or
               intersects(birdX, birdY, birdX + 34, birdY + 24, p.x, p.gapY + 50, p.x + 52, 400) then
                state = "gameover"
                if score > cfg.highscore then
                    cfg.highscore = score
                    pcall(function() writefile("flappy_highscore.txt", tostring(score)) end)
                    print("new highscore " .. tostring(score))
                end
                print("pipe hit")
                for _ = 1, 12 do
                    spawn_particle(
                        birdX + 17,
                        birdY + 12,
                        math.random(-120, 120),
                        math.random(-150, 50),
                        Color3.fromRGB(255, math.random(80, 200), 20),
                        2.0 + math.random() * 2.0,
                        2.0 + math.random() * 1.5
                    )
                end
            end
            
            if birdX > p.x + 52 and not p.passed then
                p.passed = true
                score = score + 1
                print("point scored " .. tostring(score))
            end
        end
    elseif state == "gameover" then
        local landed = false
        for i = 1, #pipes do
            local p = pipes[i]
            if birdX + 30 > p.x and birdX + 4 < p.x + 52 then
                local topOfBotPipe = p.gapY + 50
                if birdY + 24 >= topOfBotPipe then
                    birdY = topOfBotPipe - 24
                    vy = 0
                    landed = true
                    break
                end
            end
        end
        if not landed then
            if birdY + 24 < 400 then
                vy = vy + cfg.gravity * dt
                birdY = birdY + vy * dt
                if birdY + 24 >= 400 then
                    birdY = 400 - 24
                    vy = 0
                end
            end
        end
    end
    
    for i = #particles, 1, -1 do
        local p = particles[i]
        p.x = p.x + p.vx * dt
        p.y = p.y + p.vy * dt
        p.vy = p.vy + 200 * dt
        p.life = p.life - p.decay * dt
        if p.life <= 0 or not cfg.active then
            p.draw:Remove()
            table.remove(particles, i)
        else
            p.draw.Position = Vector2.new(gameX + p.x * scale, gameY + p.y * scale)
            p.draw.Radius = p.size * scale
            p.draw.Transparency = p.life
            p.draw.Visible = true
        end
    end
    
    draw_border.Visible = true
    draw_border.Filled = true
    draw_border.Color = Color3.fromRGB(20, 20, 25)
    draw_border.Size = Vector2.new(w + 10, h + 10)
    draw_border.Position = Vector2.new(gameX - 5, gameY - 5)
    draw_border.ZIndex = 0
    
    draw_left_cover.Visible = true
    draw_left_cover.Filled = true
    draw_left_cover.Color = Color3.fromRGB(20, 20, 25)
    draw_left_cover.Size = Vector2.new(gameX, screen.Y)
    draw_left_cover.Position = Vector2.new(0, 0)
    draw_left_cover.ZIndex = 4
    
    draw_right_cover.Visible = true
    draw_right_cover.Filled = true
    draw_right_cover.Color = Color3.fromRGB(20, 20, 25)
    draw_right_cover.Size = Vector2.new(math.max(0, screen.X - (gameX + w)), screen.Y)
    draw_right_cover.Position = Vector2.new(gameX + w, 0)
    draw_right_cover.ZIndex = 4
    
    draw_bg.Visible = true
    draw_bg.Size = Vector2.new(w, h)
    draw_bg.Position = Vector2.new(gameX, gameY)
    draw_bg.ZIndex = 1
    set_asset(draw_bg, "background-" .. cfg.theme)
    
    draw_base.Visible = true
    draw_base.Size = Vector2.new(336 * scale, 112 * scale)
    draw_base.Position = Vector2.new(gameX - groundOffsetX * scale, gameY + 400 * scale)
    draw_base.ZIndex = 3
    set_asset(draw_base, "base")
    
    draw_bird.Visible = true
    draw_bird.Size = Vector2.new(34 * scale, 24 * scale)
    draw_bird.Position = Vector2.new(gameX + birdX * scale, gameY + birdY * scale)
    draw_bird.ZIndex = 5
    set_asset(draw_bird, cfg.skin .. "bird-" .. ({"downflap", "midflap", "upflap"})[flapFrame])
    pcall(function()
        local angle = math.clamp(vy * 0.15, -20, 70)
        draw_bird.Rotation = angle
    end)
    
    for i = 1, 3 do
        local p = pipes[i]
        local topDraw = draw_pipes[(i-1)*2 + 1]
        local botDraw = draw_pipes[(i-1)*2 + 2]
        if p then
            topDraw.Size = Vector2.new(52 * scale, (p.gapY - 50) * scale)
            topDraw.Position = Vector2.new(gameX + p.x * scale, gameY)
            topDraw.ZIndex = 2
            set_asset(topDraw, "pipe-" .. cfg.pipecol .. "-flipped")
            topDraw.Visible = true
            
            botDraw.Size = Vector2.new(52 * scale, (400 - (p.gapY + 50)) * scale)
            botDraw.Position = Vector2.new(gameX + p.x * scale, gameY + (p.gapY + 50) * scale)
            botDraw.ZIndex = 2
            set_asset(botDraw, "pipe-" .. cfg.pipecol)
            botDraw.Visible = true
        else
            topDraw.Visible = false
            botDraw.Visible = false
        end
    end
    
    draw_message.Visible = (state == "menu")
    if draw_message.Visible then
        draw_message.Size = Vector2.new(184 * scale, 267 * scale)
        draw_message.Position = Vector2.new(gameX + (w - 184 * scale) / 2, gameY + (h - 267 * scale) / 2)
        draw_message.ZIndex = 5
        set_asset(draw_message, "message")
    end
    
    draw_gameover.Visible = (state == "gameover")
    if draw_gameover.Visible then
        draw_gameover.Size = Vector2.new(192 * scale, 42 * scale)
        draw_gameover.Position = Vector2.new(gameX + (w - 192 * scale) / 2, gameY + 100 * scale)
        draw_gameover.ZIndex = 5
        set_asset(draw_gameover, "gameover")
    end
    
    local scoreStr = tostring(score)
    local len = #scoreStr
    for i = 1, 4 do
        local digDraw = draw_digits[i]
        if i <= len and state ~= "menu" then
            set_asset(digDraw, string.sub(scoreStr, i, i))
            digDraw.Size = Vector2.new(24 * scale, 36 * scale)
            digDraw.Position = Vector2.new(gameX + (w - len * 24 * scale) / 2 + (i-1) * 24 * scale, gameY + 50 * scale)
            digDraw.ZIndex = 5
            digDraw.Visible = true
        else
            digDraw.Visible = false
        end
    end
    
    local hsStr = tostring(cfg.highscore)
    local hsLen = #hsStr
    for i = 1, 4 do
        local digDraw = draw_high_digits[i]
        if i <= hsLen and state ~= "menu" then
            set_asset(digDraw, string.sub(hsStr, i, i))
            digDraw.Size = Vector2.new(16 * scale, 24 * scale)
            digDraw.Position = Vector2.new(gameX + (w - hsLen * 16 * scale) / 2 + (i-1) * 16 * scale, gameY + 440 * scale)
            digDraw.ZIndex = 5
            digDraw.Visible = true
        else
            digDraw.Visible = false
        end
    end
    
    draw_highscore.Visible = false
end))

