        url = "https://raw.githubusercontent.com/StanislavPetrovV/DOOM-style-Game/main/resources/textures/4.png"
    elseif name == "sky" then
        url = "https://raw.githubusercontent.com/StanislavPetrovV/DOOM-style-Game/main/resources/textures/sky.png"
    elseif name == "medkit" then
        url = "https://raw.githubusercontent.com/StanislavPetrovV/DOOM-style-Game/main/resources/sprites/static_sprites/medkit.png"
    elseif name == "candle" then
        url = "https://raw.githubusercontent.com/StanislavPetrovV/DOOM-style-Game/main/resources/sprites/static_sprites/candlebra.png"
    elseif name == "ammo" then
        url = "https://raw.githubusercontent.com/StanislavPetrovV/DOOM-style-Game/main/resources/sprites/static_sprites/ammo.png"
    elseif name == "keycard" then
        url = "https://raw.githubusercontent.com/StanislavPetrovV/DOOM-style-Game/main/resources/sprites/static_sprites/keycard.png"
    end
    
    if url ~= "" then
        local success, result = pcall(function()
            return game:HttpGet(url)
        end)
        if success and result and #result > 0 and string.sub(result, 1, 4) == "\137PNG" then
            assets_cache[name] = result
            return result
        end
    end
    
    if string.find(name, "wall_slice_") then
        local w_idx, s_idx = string.match(name, "wall_slice_(%d+)_(%d+)")
        if w_idx and s_idx then
            local raw_url = "https://raw.githubusercontent.com/StanislavPetrovV/DOOM-style-Game/main/resources/textures/" .. w_idx .. ".png"
            local success, result = pcall(function()
                return game:HttpGet("https://images.weserv.nl/?url=" .. raw_url .. "&w=128&h=128&fit=cover&crop=16,128," .. ((tonumber(s_idx) - 1) * 16) .. ",0&output=png")
            end)
            if success and result and #result > 0 and string.sub(result, 1, 4) == "\137PNG" then
                assets_cache[name] = result
                return result
            end
        end
    end
    
    local fb = ""
    if data_fallback[name] then
        fb = base64decode(data_fallback[name])
    end
    if fb == "" then
        if name == "shotgun_shoot1" then
            fb = base64decode(data_fallback["shotgun_shoot"])
        elseif string.find(name, "shotgun") then
            fb = base64decode(data_fallback["shotgun_idle"])
        elseif string.find(name, "imp") then
            fb = base64decode(data_fallback["imp_walk1"])
        else
            fb = base64decode(data_fallback["medkit"])
        end
    end
    assets_cache[name] = fb
    return fb
end

