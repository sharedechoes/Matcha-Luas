function editor.start(window, on_launch)
    editor_active = true
    pcall(makefolder, "DOOMData")
    pcall(makefolder, "DOOMData/maps")
    
    for y = 0, 15 do
        for x = 0, 15 do
            local idx = y * 16 + x + 1
            local sq = Drawing.new("Square")
            sq.Size = Vector2.new(18, 18)
            sq.Position = Vector2.new(100 + x * 20, 120 + y * 20)
            sq.Filled = true
            sq.Visible = true
            editor_objects[idx] = sq
        end
    end
    
    update_grid_visuals()
    
    local sec = window:addTab("editor"):addSection("controls", "Left")
    sec:addDropdown("brush_sel", "brush tool", brush_names, {"wall grey"}, function(val)
        local sel = val[1] or "wall grey"
        brush = brush_values[sel] or 0
    end)
    
    sec:addButton("clear grid", function()
        for i = 1, 256 do
            map.grid[i] = 0
        end
        map.entities = {}
        update_grid_visuals()
        print("cleared grid")
    end)
    
    sec:addButton("export map", function()
        local data_str = game:GetService("HttpService"):JSONEncode(map)
        setclipboard(data_str)
        print("map copied to clipboard")
    end)
    
    sec:addInput("import_box", "paste level data", "", function(text)
        if #text > 10 then
            local success, decoded = pcall(function()
                return game:GetService("HttpService"):JSONDecode(text)
            end)
            if success and decoded and decoded.grid then
                map.grid = decoded.grid
                map.spawn = decoded.spawn or {x = 3.5, y = 3.5}
                map.entities = decoded.entities or {}
                update_grid_visuals()
                print("map imported")
            else
                warn("invalid map data pasted")
            end
        end
    end)
    
    local save_name = ""
    sec:addInput("save_map_name", "map save name", "", function(text)
        save_name = text
    end)
    
    local map_dropdown = nil
    
    local function refresh_maps()
        local success, files = pcall(listfiles, "DOOMData/maps")
        local items = {}
        if success and type(files) == "table" then
            for _, filepath in ipairs(files) do
                if string.find(filepath, "[\\/]") then
                    filepath = string.match(filepath, "[^\\/]+$")
                end
                if string.sub(filepath, -5) == ".json" then
                    filepath = string.sub(filepath, 1, -6)
                end
                table.insert(items, filepath)
            end
        end
        if map_dropdown then
            map_dropdown:updateChoices(items)
        end
    end
    
    sec:addButton("save map file", function()
        if save_name ~= "" then
            local success, err = pcall(function()
                local path = "DOOMData/maps/" .. save_name .. ".json"
                local json = game:GetService("HttpService"):JSONEncode(map)
                writefile(path, json)
            end)
            if success then
                print("map saved")
                refresh_maps()
            else
                warn("failed to save map")
            end
        else
            warn("enter a map save name")
        end
    end)
    
    local selected_load_map = ""
    map_dropdown = sec:addDropdown("load_map_sel", "select map file", {}, {}, function(val)
        if type(val) == "table" and val[1] then
            selected_load_map = val[1]
        elseif type(val) == "string" then
            selected_load_map = val
        end
    end)
    
    sec:addButton("load map file", function()
        if selected_load_map ~= "" then
            local path = "DOOMData/maps/" .. selected_load_map .. ".json"
            local success, data = pcall(readfile, path)
            if success and data then
                local decode_success, decoded = pcall(function()
                    return game:GetService("HttpService"):JSONDecode(data)
                end)
                if decode_success and decoded and decoded.grid then
                    map = decoded
                    if not map.entities then map.entities = {} end
                    if not map.spawn then map.spawn = {x = 2.5, y = 2.5, dirX = 1, dirY = 0} end
                    update_grid_visuals()
                    print("map loaded")
                else
                    warn("invalid map data")
                end
            else
                warn("couldnt read map file")
            end
        else
            warn("select a map to load")
        end
    end)
    
    refresh_maps()
    
    sec:addButton("test level", function()
        editor_active = false
        for i = 1, 256 do
            if editor_objects[i] then
                editor_objects[i]:Remove()
                editor_objects[i] = nil
            end
        end
        print("launching level map")
        on_launch()
    end)
    
    task.spawn(function()
        while editor_active do
            local mouse = select(2, pcall(function() return game:GetService("Players").LocalPlayer:GetMouse() end))
            if mouse and ismouse1pressed() then
                local mx, my = mouse.X, mouse.Y
                local grid_x = math.floor((mx - 100) / 20)
                local grid_y = math.floor((my - 120) / 20)
                if grid_x >= 0 and grid_x < 16 and grid_y >= 0 and grid_y < 16 then
                    local idx = grid_y * 16 + grid_x + 1
                    if brush == 5 then
                        map.spawn.x = grid_x + 0.5
                        map.spawn.y = grid_y + 0.5
                        for i = 1, 256 do
                            if map.grid[i] == 5 then map.grid[i] = 0 end
                        end
                        map.grid[idx] = 5
                    elseif brush >= 20 then
                        local found = false
                        for i = #map.entities, 1, -1 do
                            if math.floor(map.entities[i].x) == grid_x and math.floor(map.entities[i].y) == grid_y then
                                found = true
                                break
                            end
                        end
                        if not found then
                            local ent_type = "medkit"
                            for name, val in pairs(brush_values) do
                                if val == brush then
                                    ent_type = name
                                    break
                                end
                            end
                            table.insert(map.entities, {
                                type = ent_type,
                                x = grid_x + 0.5,
                                y = grid_y + 0.5
                            })
                            map.grid[idx] = brush
                        end
                    else
                        map.grid[idx] = brush
                        for i = #map.entities, 1, -1 do
                            if math.floor(map.entities[i].x) == grid_x and math.floor(map.entities[i].y) == grid_y then
                                table.remove(map.entities, i)
                            end
                        end
                    end
                    update_grid_visuals()
                end
            elseif mouse and ismouse2pressed() then
                local mx, my = mouse.X, mouse.Y
                local grid_x = math.floor((mx - 100) / 20)
                local grid_y = math.floor((my - 120) / 20)
                if grid_x >= 0 and grid_x < 16 and grid_y >= 0 and grid_y < 16 then
                    local idx = grid_y * 16 + grid_x + 1
                    map.grid[idx] = 0
                    for i = #map.entities, 1, -1 do
                        if math.floor(map.entities[i].x) == grid_x and math.floor(map.entities[i].y) == grid_y then
                            table.remove(map.entities, i)
                        end
                    end
                    update_grid_visuals()
                end
            end
            task.wait(0.05)
        end
    end)
end

function editor.stop()
    editor_active = false
    for i = 1, 256 do
        if editor_objects[i] then
            editor_objects[i]:Remove()
            editor_objects[i] = nil
        end
    end
end

