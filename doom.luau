function engine.start(window, on_back_to_editor)
    engine_active = true
    
    local function has_los(x1, y1, x2, y2)
        local dx = x2 - x1
        local dy = y2 - y1
        local steps = math.floor(math.max(math.abs(dx), math.abs(dy)) * 2)
        if steps == 0 then return true end
        for step = 1, steps do
            local tx = x1 + dx * (step / steps)
            local ty = y1 + dy * (step / steps)
            if map.grid[math.floor(ty) * 16 + math.floor(tx) + 1] > 0 then
                return false
            end
        end
        return true
    end
    
    local posX = map.spawn.x
    local posY = map.spawn.y
    local dirX = map.spawn.dirX or 1
    local dirY = map.spawn.dirY or 0
    local planeX = -dirY * 0.66
    local planeY = dirX * 0.66
    
    local health = 100
    local ammo = 20
    local score = 0
    local is_shooting = 0
    local shoot_time = 0
    
    local items = {}
    for _, ent in ipairs(map.entities) do
        if ent.type == "medkit" or ent.type == "ammo" or ent.type == "keycard" or ent.type == "candle" then
            table.insert(items, {x = ent.x, y = ent.y, active = true, type = ent.type})
        end
    end
    
    local enemies = {}
    for _, ent in ipairs(map.entities) do
        local is_enemy = false
        if ent.type == "imp" or ent.type == "cacodemon" or ent.type == "cyberdemon" or ent.type == "zombie soldier" or ent.type == "lost soul" or ent.type == "baron of hell" then
            is_enemy = true
        end
        if is_enemy then
            local enemy_hp = 2
            if ent.type == "zombie soldier" or ent.type == "lost soul" then
                enemy_hp = 1
            elseif ent.type == "cacodemon" then
                enemy_hp = 4
            elseif ent.type == "baron of hell" then
                enemy_hp = 8
            elseif ent.type == "cyberdemon" then
                enemy_hp = 20
            end
            table.insert(enemies, {
                x = ent.x,
                y = ent.y,
                state = "idle",
                hp = enemy_hp,
                type = ent.type,
                anim_state = "walk",
                anim_frame = 1,
                last_anim_tick = 0,
                death_tick = 0
            })
        end
    end
    
    local screen = select(2, pcall(function() return workspace.CurrentCamera.ViewportSize end)) or Vector2.new(800, 600)
    local screenWidth = screen.X
    local screenHeight = screen.Y
    
    wall_textures = {}
    sprite_textures = {}
    
    pcall(function()
        workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
        if game:GetService("Players").LocalPlayer.Character then
            for _, part in ipairs(game:GetService("Players").LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Anchored = true
                end
            end
        end
    end)
    
    bg = Drawing.new("Square")
    bg.Size = Vector2.new(screenWidth, screenHeight)
    bg.Position = Vector2.new(0, 0)
    bg.Filled = true
    bg.Color = Color3.fromRGB(40, 40, 45)
    bg.Visible = true
    bg.ZIndex = 1
    
    sky1 = Drawing.new("Image")
    sky1.Size = Vector2.new(screenWidth * 2, screenHeight / 2)
    sky1.Position = Vector2.new(0, 0)
    sky1.Data = get_asset("sky")
    sky1.Visible = true
    sky1.ZIndex = 2
    
    sky2 = Drawing.new("Image")
    sky2.Size = Vector2.new(screenWidth * 2, screenHeight / 2)
    sky2.Position = Vector2.new(screenWidth * 2, 0)
    sky2.Data = get_asset("sky")
    sky2.Visible = true
    sky2.ZIndex = 2
    
    crosshair = Drawing.new("Circle")
