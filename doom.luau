    crosshair.Color = Color3.fromRGB(255, 0, 0)
    crosshair.Filled = true
    crosshair.Position = Vector2.new(screenWidth / 2, screenHeight / 2)
    crosshair.Visible = true
    crosshair.ZIndex = 5
    
    for i = 1, 160 do
        local img = Drawing.new("Image")
        img.Visible = false
        img.ZIndex = 3
        wall_images[i] = img
    end
    
    for i = 1, 16 do
        local sp = Drawing.new("Image")
        sp.Visible = false
        sp.ZIndex = 4
        sprites[i] = sp
    end
    
    local wSize = math.floor(screenHeight * 0.5)
    weapon = Drawing.new("Image")
    weapon.Size = Vector2.new(wSize, wSize)
    weapon.Position = Vector2.new((screenWidth - wSize) / 2, screenHeight - wSize)
    weapon.Data = get_asset("shotgun_idle")
    weapon.Visible = true
    weapon.ZIndex = 5
    
    hud = Drawing.new("Text")
    hud.Size = 16
    hud.Color = Color3.fromRGB(255, 0, 0)
    hud.Position = Vector2.new(20, 20)
    hud.Visible = true
    hud.ZIndex = 6

    interact_prompt = Drawing.new("Text")
    interact_prompt.Size = 20
    interact_prompt.Color = Color3.fromRGB(255, 255, 255)
    interact_prompt.Center = true
    interact_prompt.Outline = true
    interact_prompt.Position = Vector2.new(screenWidth / 2, screenHeight * 0.7)
    interact_prompt.Text = "press E to interact"
    interact_prompt.Visible = false
    interact_prompt.ZIndex = 7
    
    local keys_pressed = {}
    
    key_connection = game:GetService("UserInputService").InputBegan:Connect(function(input)
        local key = tostring(input.KeyCode)
        keys_pressed[key] = true
        if input.KeyCode == Enum.KeyCode.Escape then
            engine.stop()
            on_back_to_editor()
            return
        end
        if input.KeyCode == Enum.KeyCode.E then
            local gridX = math.floor(posX + dirX * 1.5)
            local gridY = math.floor(posY + dirY * 1.5)
            if gridX >= 0 and gridX < 16 and gridY >= 0 and gridY < 16 then
                local idx = gridY * 16 + gridX + 1
                local cell = map.grid[idx]
                if cell == 4 or cell == 11 or cell == 12 or cell == 13 then
                    local locked = false
                    if cell == 11 and not keys_obtained.red then locked = true print("red keycard required ") end
                    if cell == 12 and not keys_obtained.blue then locked = true print("blue keycard required ") end
                    if cell == 13 and not keys_obtained.yellow then locked = true print("yellow keycard required ") end
                    
                    if not locked then
                        if not door_states[idx] or door_states[idx] == "closed" then
                            door_states[idx] = "opening"
                            door_progress[idx] = 0
                            door_types[idx] = cell
                            print("door opening")
                        end
                    end
                end
            end
            for idx = 1, #items do
                local item = items[idx]
                if item.active then
                    local ix = item.x - posX
                    local iy = item.y - posY
                    if ix*ix + iy*iy < 3.24 then
                        local angle = math.atan2(iy, ix) - math.atan2(dirY, dirX)
                        if angle < -math.pi then angle = angle + 2*math.pi end
                        if angle > math.pi then angle = angle - 2*math.pi end
                        if math.abs(angle) < 0.3 then
                            item.active = false
                            if item.type == "medkit" or item.type == "health bonus" or item.type == "supercharge" or item.type == "megasphere" then
                                local gain = 25
                                if item.type == "health bonus" then gain = 5 end
                                if item.type == "supercharge" then gain = 100 end
                                if item.type == "megasphere" then gain = 200 end
                                health = health + gain
                                if health > (item.type == "supercharge" and 200 or (item.type == "megasphere" and 200 or 100)) then
                                    health = item.type == "supercharge" and 200 or (item.type == "megasphere" and 200 or 100)
                                end
                                print(item.type .. " obtained ")
                            elseif item.type == "ammo pack" or item.type == "shotgun pickup" or item.type == "rocket launcher" or item.type == "plasma rifle" then
                                local gain = 10
                                if item.type == "shotgun pickup" then gain = 20 end
                                ammo = ammo + gain
                                print(item.type .. " obtained ")
                            elseif item.type == "red keycard" then
                                keys_obtained.red = true
                                print("red keycard obtained ")
                            elseif item.type == "blue keycard" then
                                keys_obtained.blue = true
                                print("blue keycard obtained")
                            elseif item.type == "yellow keycard" then
                                keys_obtained.yellow = true
                                print("yellow keycard obtained")
                            end
                            break
                        end
                    end
                end
            end
        end
        if input.KeyCode == Enum.KeyCode.Space or input.KeyCode == Enum.KeyCode.MouseButton1 then
            if is_shooting == 0 and ammo > 0 then
                is_shooting = 1
                shoot_time = tick()
                ammo = ammo - 1
                weapon.Data = get_asset("shotgun_shoot1")
                
                local hit_enemy = nil
                local min_d = 100
                for idx = 1, #enemies do
                    local enemy = enemies[idx]
                    if enemy.hp > 0 then
                        local ex = enemy.x - posX
                        local ey = enemy.y - posY
                        local angle = math.atan2(ey, ex) - math.atan2(dirY, dirX)
                        if angle < -math.pi then angle = angle + 2*math.pi end
                        if angle > math.pi then angle = angle - 2*math.pi end
                        if math.abs(angle) < 0.15 then
                            local d = math.sqrt(ex*ex + ey*ey)
                            if d < min_d then
                                min_d = d
                                hit_enemy = enemy
                            end
                        end
                    end
                end
                
                if hit_enemy then
                    hit_enemy.hp = hit_enemy.hp - 1
                    print("you shot a " .. hit_enemy.type .. "")
                    if hit_enemy.hp <= 0 then
                        local points = 100
                        if hit_enemy.type == "cyberdemon" then points = 1000
                        elseif hit_enemy.type == "baron of hell" then points = 500
                        end
                        score = score + points
                        print(hit_enemy.type .. " died")
                    end
                else
                    print("shot msised")
                end
            end
        end
    end)
    
    key_end_conn = game:GetService("UserInputService").InputEnded:Connect(function(input)
        keys_pressed[tostring(input.KeyCode)] = nil
    end)
    
    local zBuffer = {}
    local dt = 0.016
    local last_tick = tick()
    
    local run_service = select(2, pcall(function() return game:GetService("RunService") end)) or { RenderStepped = { Connect = function() return { Disconnect = function() end } end } }
    loop_connection = run_service.RenderStepped:Connect(function()
        if not engine_active then return end
        dt = tick() - last_tick
        last_tick = tick()
        
        if health <= 0 then
            hud.Text = "GAME OVER  SCORE: " .. score
            weapon.Visible = false
            return
        end
        
        local moveSpeed = 2.2 * dt
        local rotSpeed = 1.2 * dt
        
        if keys_pressed[tostring(Enum.KeyCode.W)] then
            local gx = math.floor(posX + dirX * moveSpeed)
            if gx >= 0 and gx < 16 then
                local valX = map.grid[math.floor(posY) * 16 + gx + 1]
                if valX and (valX == 0 or valX >= 5) then posX = posX + dirX * moveSpeed end
            end
            local gy = math.floor(posY + dirY * moveSpeed)
            if gy >= 0 and gy < 16 then
                local valY = map.grid[gy * 16 + math.floor(posX) + 1]
                if valY and (valY == 0 or valY >= 5) then posY = posY + dirY * moveSpeed end
            end
        end
        if keys_pressed[tostring(Enum.KeyCode.S)] then
            local gx = math.floor(posX - dirX * moveSpeed)
            if gx >= 0 and gx < 16 then
                local valX = map.grid[math.floor(posY) * 16 + gx + 1]
                if valX and (valX == 0 or valX >= 5) then posX = posX - dirX * moveSpeed end
            end
            local gy = math.floor(posY - dirY * moveSpeed)
            if gy >= 0 and gy < 16 then
                local valY = map.grid[gy * 16 + math.floor(posX) + 1]
                if valY and (valY == 0 or valY >= 5) then posY = posY - dirY * moveSpeed end
            end
        end
        if keys_pressed[tostring(Enum.KeyCode.A)] then
            dirX, dirY = dirX * math.cos(-rotSpeed) - dirY * math.sin(-rotSpeed), dirX * math.sin(-rotSpeed) + dirY * math.cos(-rotSpeed)
            planeX, planeY = planeX * math.cos(-rotSpeed) - planeY * math.sin(-rotSpeed), planeX * math.sin(-rotSpeed) + planeY * math.cos(-rotSpeed)
        end
        if keys_pressed[tostring(Enum.KeyCode.D)] then
            dirX, dirY = dirX * math.cos(rotSpeed) - dirY * math.sin(rotSpeed), dirX * math.sin(rotSpeed) + dirY * math.cos(rotSpeed)
            planeX, planeY = planeX * math.cos(rotSpeed) - planeY * math.sin(rotSpeed), planeX * math.sin(rotSpeed) + planeY * math.cos(rotSpeed)
        end
        
        local offset = -math.floor(((math.atan2(dirY, dirX) + math.pi) / (2 * math.pi)) * (screenWidth * 2))
        sky1.Position = Vector2.new(offset, 0)
        sky2.Position = Vector2.new(offset + screenWidth * 2, 0)
        crosshair.Position = Vector2.new(screenWidth / 2, screenHeight / 2)
        
        if is_shooting == 1 then
            local t = tick() - shoot_time
            local weapon_frame = "shotgun_idle"
            if t < 0.08 then
                weapon_frame = "shotgun_shoot1"
            elseif t < 0.16 then
                weapon_frame = "shotgun_shoot2"
            elseif t < 0.24 then
                weapon_frame = "shotgun_shoot3"
            elseif t < 0.32 then
                weapon_frame = "shotgun_shoot4"
            else
                is_shooting = 0
            end
            if weapon_texture ~= weapon_frame then
                weapon.Data = get_asset(weapon_frame)
                weapon_texture = weapon_frame
            end
        else
            if weapon_texture ~= "shotgun_idle" then
                weapon.Data = get_asset("shotgun_idle")
                weapon_texture = "shotgun_idle"
            end
        end
        
        for idx, state in pairs(door_states) do
            if state == "opening" then
                door_progress[idx] = (door_progress[idx] or 0) + dt * 2.0
                if door_progress[idx] >= 0.95 then
                    door_progress[idx] = 0.95
                    door_states[idx] = "open"
                    map.grid[idx] = 0
                    task.delay(4, function()
                        local orig_type = door_types[idx] or 4
                        if math.floor(posX) == (idx - 1) % 16 and math.floor(posY) == math.floor((idx - 1) / 16) then
                            task.delay(2, function()
                                map.grid[idx] = orig_type
                                door_states[idx] = "closing"
                            end)
                        else
                            map.grid[idx] = orig_type
                            door_states[idx] = "closing"
                        end
                    end)
                end
            elseif state == "closing" then
                door_progress[idx] = (door_progress[idx] or 0.95) - dt * 2.0
                if door_progress[idx] <= 0 then
                    door_progress[idx] = 0
                    door_states[idx] = "closed"
                end
            end
        end
        
        local columns_data = {}
        local colWidth = screenWidth / 100
        for x = 0, 100 - 1 do
            local cameraX = 2 * x / 100 - 1
            local rayDirX = dirX + planeX * cameraX
            local rayDirY = dirY + planeY * cameraX
            
            local mapX = math.floor(posX)
            local mapY = math.floor(posY)
            
            local deltaDistX = (rayDirX == 0) and 1e30 or math.abs(1 / rayDirX)
            local deltaDistY = (rayDirY == 0) and 1e30 or math.abs(1 / rayDirY)
            
            local stepX, stepY
            local sideDistX, sideDistY
            
            if rayDirX < 0 then
                stepX = -1
                sideDistX = (posX - mapX) * deltaDistX
            else
                stepX = 1
                sideDistX = (mapX + 1.0 - posX) * deltaDistX
            end
            if rayDirY < 0 then
                stepY = -1
                sideDistY = (posY - mapY) * deltaDistY
            else
                stepY = 1
                sideDistY = (mapY + 1.0 - posY) * deltaDistY
            end
            
            local hit = 0
            local side = 0
            local wallType = 0
            
            while hit == 0 do
                if sideDistX < sideDistY then
                    sideDistX = sideDistX + deltaDistX
                    mapX = mapX + stepX
                    side = 0
                else
                    sideDistY = sideDistY + deltaDistY
                    mapY = mapY + stepY
                    side = 1
                end
                
                if mapX < 0 or mapX >= 16 or mapY < 0 or mapY >= 16 then
                    hit = 1
                    wallType = 1
                else
                    local val = map.grid[mapY * 16 + mapX + 1]
                    if (val > 0 and val <= 4) or (val >= 10 and val <= 17) then
                        if val == 4 or val == 11 or val == 12 or val == 13 then
                            local perpWallDist
                            if side == 0 then
                                perpWallDist = (mapX - posX + (1 - stepX) / 2) / rayDirX
                            else
                                perpWallDist = (mapY - posY + (1 - stepY) / 2) / rayDirY
                            end
                            local wallX
                            if side == 0 then
                                wallX = posY + perpWallDist * rayDirY
                            else
                                wallX = posX + perpWallDist * rayDirX
                            end
                            wallX = wallX - math.floor(wallX)
                            
                            local progress = door_progress[mapY * 16 + mapX + 1] or 0
                            if wallX >= progress then
                                hit = 1
                                wallType = val
                            end
                        else
                            hit = 1
                            wallType = val
                        end
                    end
                end
            end
            
            local perpWallDist
            if side == 0 then
                perpWallDist = (mapX - posX + (1 - stepX) / 2) / rayDirX
            else
                perpWallDist = (mapY - posY + (1 - stepY) / 2) / rayDirY
            end
            
            if perpWallDist <= 0 then perpWallDist = 0.01 end
            zBuffer[x + 1] = perpWallDist
            
            local lineHeight = math.floor(screenHeight / perpWallDist)
            local drawStart = -lineHeight / 2 + (screenHeight / 2)
            
            columns_data[x + 1] = {
                wallType = wallType,
                side = side,
                dist = perpWallDist,
                drawStart = drawStart,
                lineHeight = lineHeight,
                mapX = mapX,
                mapY = mapY
            }
        end
        
        local spans = {}
        local current_span = nil
        for x = 0, 100 - 1 do
            local col = columns_data[x + 1]
            if col.wallType > 0 then
                if not current_span then
                    current_span = {
                        startX = x,
                        endX = x,
                        wallType = col.wallType,
                        side = col.side,
                        mapX = col.mapX,
                        mapY = col.mapY
                    }
                else
                    if col.wallType == current_span.wallType and col.side == current_span.side and col.mapX == current_span.mapX and col.mapY == current_span.mapY then
                        current_span.endX = x
                    else
                        table.insert(spans, current_span)
                        current_span = {
                            startX = x,
                            endX = x,
                            wallType = col.wallType,
                            side = col.side,
                            mapX = col.mapX,
                            mapY = col.mapY
                        }
                    end
                end
            else
                if current_span then
                    table.insert(spans, current_span)
                    current_span = nil
                end
            end
        end
        if current_span then
            table.insert(spans, current_span)
        end
        
        local pool_idx = 0
        local colWidth = screenWidth / 100
        local wall_base_tex = {
            [1] = 1, [2] = 2, [3] = 3, [4] = 4,
            [10] = 5, [11] = 7, [12] = 8, [13] = 9, [14] = 6, [15] = 3, [16] = 6, [17] = 2
        }
        local wall_base_tint = {
            [1] = Color3.fromRGB(255, 255, 255),
            [2] = Color3.fromRGB(255, 255, 255),
            [3] = Color3.fromRGB(255, 255, 255),
            [4] = Color3.fromRGB(255, 255, 255),
            [10] = Color3.fromRGB(255, 255, 255),
            [11] = Color3.fromRGB(255, 255, 255),
            [12] = Color3.fromRGB(255, 255, 255),
            [13] = Color3.fromRGB(255, 255, 255),
            [14] = Color3.fromRGB(255, 255, 255),
            [15] = Color3.fromRGB(255, 255, 255),
            [16] = Color3.fromRGB(255, 255, 255),
            [17] = Color3.fromRGB(255, 255, 255)
        }
        for idx = 1, #spans do
            local span = spans[idx]
            local span_cols = span.endX - span.startX + 1
            for s = 1, 8 do
                pool_idx = pool_idx + 1
                local img = wall_images[pool_idx]
                if img then
                    local x1 = math.floor(span.startX * colWidth + (s - 1) * (span_cols * colWidth / 8))
                    local col_data = columns_data[math.clamp(math.floor(span.startX + (s - 0.5) * (span_cols / 8)) + 1, 1, 100)]
                    
                    img.Position = Vector2.new(x1, col_data.drawStart)
                    img.Size = Vector2.new(math.floor(span.startX * colWidth + s * (span_cols * colWidth / 8)) - x1, col_data.lineHeight)
                    
                    local base_tex = wall_base_tex[span.wallType] or 1
                    local tex_name = "wall_slice_" .. base_tex .. "_" .. s
                    if wall_textures[pool_idx] ~= tex_name then
                        img.Data = get_asset(tex_name)
                        wall_textures[pool_idx] = tex_name
                    end
                    
                    local base_tint = wall_base_tint[span.wallType] or Color3.fromRGB(255, 255, 255)
                    local base_val = span.side == 1 and 150 or 255
                    local fog = col_data.dist / 14
                    if fog > 1 then fog = 1 end
                    img.Color = Color3.new(
                        (base_tint.R * base_val + (40 - base_tint.R * base_val) * fog) / 255,
                        (base_tint.G * base_val + (40 - base_tint.G * base_val) * fog) / 255,
                        (base_tint.B * base_val + (45 - base_tint.B * base_val) * fog) / 255
                    )
                    img.Transparency = 1
                    img.Visible = true
                end
            end
        end
        for idx = pool_idx + 1, #wall_images do
            if wall_images[idx] then
                wall_images[idx].Visible = false
            end
        end
        
        local active_sprites = {}
        for idx = 1, #items do
            local item = items[idx]
            if item.active then
                local ix = item.x - posX
                local iy = item.y - posY
                table.insert(active_sprites, {
                    x = item.x,
                    y = item.y,
                    dist = ix*ix + iy*iy,
                    type = item.type
                })
            end
        end
        
        for idx = 1, #enemies do
            local enemy = enemies[idx]
            local ex = enemy.x - posX
            local ey = enemy.y - posY
            local dist = math.sqrt(ex*ex + ey*ey)
            
            if enemy.hp <= 0 and enemy.state ~= "dead" then
                enemy.state = "dead"
                enemy.death_tick = tick()
                enemy.anim_state = "death"
                enemy.anim_frame = 1
            end
            
            if enemy.state == "dead" then
                local dt_death = tick() - enemy.death_tick
                if dt_death < 0.1 then enemy.anim_frame = 1
                elseif dt_death < 0.2 then enemy.anim_frame = 2
                elseif dt_death < 0.3 then enemy.anim_frame = 3
                elseif dt_death < 0.4 then enemy.anim_frame = 4
                else enemy.anim_frame = 5
                end
            elseif enemy.state == "idle" then
                if dist < 12 and has_los(enemy.x, enemy.y, posX, posY) then
                    enemy.state = "chase"
                end
                enemy.anim_state = "walk"
                enemy.anim_frame = 1
            elseif enemy.state == "chase" then
                if dist > 2.0 then
                    local gx = math.floor(enemy.x - (ex / dist) * 0.015)
                    if gx >= 0 and gx < 16 then
                        local valX = map.grid[math.floor(enemy.y) * 16 + gx + 1]
                        if valX and (valX == 0 or valX >= 20) then enemy.x = enemy.x - (ex / dist) * 0.015 end
                    end
                    local gy = math.floor(enemy.y - (ey / dist) * 0.015)
                    if gy >= 0 and gy < 16 then
                        local valY = map.grid[gy * 16 + math.floor(enemy.x) + 1]
                        if valY and (valY == 0 or valY >= 20) then enemy.y = enemy.y - (ey / dist) * 0.015 end
                    end
                    enemy.anim_state = "walk"
                    if tick() - enemy.last_anim_tick > 0.25 then
                        enemy.anim_frame = enemy.anim_frame == 1 and 2 or 1
                        enemy.last_anim_tick = tick()
                    end
                else
                    if tick() % 1.5 < 0.05 then
                        local dmg = 10
                        if enemy.type == "cyberdemon" then dmg = 30
                        elseif enemy.type == "baron of hell" then dmg = 20
                        elseif enemy.type == "lost soul" then dmg = 15
                        end
                        health = health - dmg
                        print(enemy.type .. " hit you rawr")
                    end
                    enemy.anim_state = "attack"
                    if tick() - enemy.last_anim_tick > 0.2 then
                        enemy.anim_frame = enemy.anim_frame == 1 and 2 or 1
                        enemy.last_anim_tick = tick()
                    end
                end
            end
            
            table.insert(active_sprites, {
                x = enemy.x,
                y = enemy.y,
                dist = ex*ex + ey*ey,
                type = "imp",
                anim_state = enemy.anim_state,
                anim_frame = enemy.anim_frame
            })
        end
        
        table.sort(active_sprites, function(a, b)
            return a.dist > b.dist
        end)
        
        for i = 1, 16 do
            local sp_img = sprites[i]
            if sp_img then
                local s = active_sprites[i]
                local visible = false
                if s then
                    local sx = s.x - posX
                    local sy = s.y - posY
                    local invDet = 1.0 / (planeX * dirY - dirX * planeY)
                    local transformX = invDet * (dirY * sx - dirX * sy)
                    local transformY = invDet * (-planeY * sx + planeX * sy)
                    
                    if transformY > 0.1 then
                        local sScreenX = math.floor((screenWidth / 2) * (1 + transformX / transformY))
                        local tex_name = s.type
                        local s_color = Color3.fromRGB(255, 255, 255)
                        local s_scale = 1.0
                        
                        if s.type == "cyberdemon" then s_scale = 1.8
                        elseif s.type == "baron of hell" then s_scale = 1.3
                        elseif s.type == "cacodemon" then s_scale = 1.2
                        elseif s.type == "tall green pillar" then s_scale = 1.0
                        elseif s.type == "hanging corpse" then s_scale = 1.0
                        elseif s.type == "tech lamp" or s.type == "eye symbol" then s_scale = 0.8
                        elseif s.type == "short green pillar" or s.type == "toxic barrel decor" then s_scale = 0.6
                        elseif s.type == "candle" then s_scale = 0.4
                        elseif s.type == "dead soldier" then s_scale = 0.3
                        elseif s.type == "medkit" or s.type == "ammo pack" or s.type == "red keycard" or s.type == "blue keycard" or s.type == "yellow keycard" or s.type == "megaarmor" or s.type == "armor bonus" or s.type == "health bonus" or s.type == "supercharge" or s.type == "megasphere" or s.type == "shotgun pickup" or s.type == "rocket launcher" or s.type == "plasma rifle" then
                            s_scale = 0.5
                        end
                        
                        if s.type == "imp" then
                            if s.anim_state == "walk" then
                                tex_name = s.anim_frame == 1 and "imp_walk1" or "imp_walk2"
                            elseif s.anim_state == "attack" then
                                tex_name = s.anim_frame == 1 and "imp_attack1" or "imp_attack2"
                            else
                                tex_name = "imp_death" .. s.anim_frame
                            end
                        end
                        
                        if transformY < zBuffer[math.clamp(math.floor((sScreenX / screenWidth) * 100) + 1, 1, 100)] then
                            local sHeight = math.abs(math.floor(screenHeight / transformY)) * s_scale
                            sp_img.Size = Vector2.new(sHeight, sHeight)
                            sp_img.Position = Vector2.new(sScreenX - sHeight / 2, -sHeight / 2 + (screenHeight / 2))
                            if sprite_textures[i] ~= tex_name then
                                sp_img.Data = get_asset(tex_name)
                                sprite_textures[i] = tex_name
                            end
                            local sfog = transformY / 14
                            if sfog > 1 then sfog = 1 end
                            local r = (s_color.R * 255 + (40 - s_color.R * 255) * sfog) / 255
                            local g = (s_color.G * 255 + (40 - s_color.G * 255) * sfog) / 255
                            local b = (s_color.B * 255 + (45 - s_color.B * 255) * sfog) / 255
                            sp_img.Color = Color3.new(r, g, b)
                            sp_img.Visible = true
                            visible = true
                        end
                    end
                end
                if not visible then
                    sp_img.Visible = false
                end
            end
        end
        local can_interact = false
        local gridX = math.floor(posX + dirX * 1.5)
        local gridY = math.floor(posY + dirY * 1.5)
        if gridX >= 0 and gridX < 16 and gridY >= 0 and gridY < 16 then
            local val = map.grid[gridY * 16 + gridX + 1]
            if val == 4 or val == 11 or val == 12 or val == 13 then
                can_interact = true
                if val == 11 and not keys_obtained.red then
                    interact_prompt.Text = "red keycard required"
                elseif val == 12 and not keys_obtained.blue then
                    interact_prompt.Text = "blue keycard required"
                elseif val == 13 and not keys_obtained.yellow then
                    interact_prompt.Text = "yellow keycard required"
                else
                    interact_prompt.Text = "press E to open door"
                end
            end
        end
        if not can_interact then
            for idx = 1, #items do
                local item = items[idx]
                if item.active then
                    local ix = item.x - posX
                    local iy = item.y - posY
                    if ix*ix + iy*iy < 3.24 then
                        local angle = math.atan2(iy, ix) - math.atan2(dirY, dirX)
                        if angle < -math.pi then angle = angle + 2*math.pi end
                        if angle > math.pi then angle = angle - 2*math.pi end
                        if math.abs(angle) < 0.3 then
                            can_interact = true
                            break
                        end
                    end
                end
            end
        end
        interact_prompt.Visible = can_interact
        
        hud.Text = "HEALTH: " .. health .. "  AMMO: " .. ammo .. "  SCORE: " .. score .. (keys_obtained.red and "  [RED]" or "") .. (keys_obtained.blue and "  [BLUE]" or "") .. (keys_obtained.yellow and "  [YELLOW]" or "") .. "  ESC TO EXIT"
    end)
end

function engine.stop()
    engine_active = false
    if loop_connection then
        loop_connection:Disconnect()
        loop_connection = nil
    end
    if key_connection then
        key_connection:Disconnect()
        key_connection = nil
    end
    if key_end_conn then
        key_end_conn:Disconnect()
        key_end_conn = nil
    end
    if bg then bg:Remove() bg = nil end
    if sky1 then sky1:Remove() sky1 = nil end
    if sky2 then sky2:Remove() sky2 = nil end
    if crosshair then crosshair:Remove() crosshair = nil end
    if weapon then weapon:Remove() weapon = nil end
    if hud then hud:Remove() hud = nil end
    if interact_prompt then interact_prompt:Remove() interact_prompt = nil end
    for i = 1, #wall_images do
        if wall_images[i] then wall_images[i]:Remove() wall_images[i] = nil end
    end
    wall_textures = {}
    sprite_textures = {}
    weapon_texture = ""
    door_progress = {}
    door_states = {}
    door_types = {}
    keys_obtained = { red = false, blue = false, yellow = false }
    for i = 1, 16 do
        if sprites[i] then sprites[i]:Remove() sprites[i] = nil end
    end
    pcall(function()
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        if game:GetService("Players").LocalPlayer.Character then
            for _, part in ipairs(game:GetService("Players").LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Anchored = false
                end
            end
        end
    end)
end

homesick.changelogEnabled = false
homesick:setTheme({
    bg = Color3.fromRGB(20, 20, 25),
